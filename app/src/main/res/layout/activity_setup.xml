<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="48dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CYBER SENSEI TV"
        android:textColor="#F24E1E"
        android:textSize="36sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Media Player Setup"
        android:textColor="#888888"
        android:textSize="16sp"
        android:layout_marginBottom="48dp" />

    <EditText
        android:id="@+id/inputServerUrl"
        android:layout_width="400dp"
        android:layout_height="56dp"
        android:background="@drawable/input_background"
        android:hint="Server URL (https://your-app.replit.app)"
        android:textColorHint="#555555"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:inputType="textUri"
        android:layout_marginBottom="16dp"
        android:singleLine="true" />

    <EditText
        android:id="@+id/inputApiKey"
        android:layout_width="400dp"
        android:layout_height="56dp"
        android:background="@drawable/input_background"
        android:hint="API Key"
        android:textColorHint="#555555"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:inputType="text"
        android:layout_marginBottom="24dp"
        android:singleLine="true" />

    <Button
        android:id="@+id/btnConnect"
        android:layout_width="400dp"
        android:layout_height="56dp"
        android:text="CONNECT"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/button_background"
        android:layout_marginBottom="16dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#CCCCCC"
        android:textSize="14sp" />

</LinearLayout>
